# Phican Ingenieros — Variables de entorno opcionales
# Copia este archivo a .env y ajusta los valores

# Puerto del servidor web (default: 5050)
# PHICAN_PORT=5050

# Host del servidor (default: 127.0.0.1 = solo local)
# PHICAN_HOST=127.0.0.1

# Modo debug Flask (default: 0 = desactivado)
# FLASK_DEBUG=0

# Clave secreta para sesiones (se genera automáticamente si no se define)
# SECRET_KEY=tu-clave-secreta-aqui
